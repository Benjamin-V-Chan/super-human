{
  "version": 1,
  "max_concurrent_workers": 3,
  "states": ["ready", "active", "blocked", "review", "done"],
  "stages": [
    {
      "id": "contract_freeze",
      "owner": "coordinator",
      "depends_on": [],
      "exit_gate": "Affected schemas, units, task IDs, fixtures, and acceptance commands are explicit."
    },
    {
      "id": "feature_slices",
      "owners": ["perception", "design_cad", "simulation"],
      "depends_on": ["contract_freeze"],
      "parallel": true,
      "exit_gate": "Each slice returns a contract-valid handoff and its focused checks pass."
    },
    {
      "id": "loop_integration",
      "owner": "coordinator",
      "depends_on": ["feature_slices"],
      "exit_gate": "One deterministic perceive-design-verify loop completes without private schemas."
    },
    {
      "id": "optimization",
      "owner": "optimization",
      "depends_on": ["loop_integration"],
      "loop": {
        "sequence": ["propose", "verify", "record", "rank"],
        "requires_iteration_limit": true,
        "requires_seed": true,
        "stop_on": ["budget exhausted", "target reward reached", "no improvement"]
      },
      "exit_gate": "Ranked candidates include rewards, seed/config, and stopping reason."
    },
    {
      "id": "manufacture_and_present",
      "owners": ["design_cad", "viewer_api"],
      "depends_on": ["optimization"],
      "parallel": false,
      "exit_gate": "The selected candidate is exported once and the API/viewer consumes the shared schema."
    },
    {
      "id": "qa_evidence",
      "owner": "qa_evidence",
      "depends_on": ["manufacture_and_present"],
      "exit_gate": "Applicable repository gates pass and skipped gates are explained."
    }
  ],
  "shared_path_policy": {
    "paths": [
      "prosthesis_rl/contracts/**",
      "prosthesis_rl/agents/orchestrator.py",
      "tasks.py"
    ],
    "default_owner": "coordinator",
    "rule": "A task must explicitly delegate a shared path before another role writes it."
  }
}

