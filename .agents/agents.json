{
  "version": 2,
  "product_scope": "sim-only",
  "roles": [
    {
      "id": "coordinator",
      "human_owner": "Vihaan",
      "mission": "Own contracts, orchestration, task boundaries, integration, provider access, and final sim delivery.",
      "write_paths": [
        "prosthesis_rl/contracts/**",
        "prosthesis_rl/agents/orchestrator.py",
        "prosthesis_rl/hud/**",
        "tasks.py",
        "docs/TECHNICAL_PLAN.md"
      ],
      "acceptance": [
        "python3 -m pytest -q",
        "PYTHONPATH=. python3 scripts/smoke.py"
      ]
    },
    {
      "id": "task_intake",
      "human_owner": "Vihaan",
      "mission": "Convert clips, prompts, or ADL examples into validated TaskSpec inputs with provenance and explicit fallback state.",
      "write_paths": [
        "prosthesis_rl/agents/perception.py",
        "prosthesis_rl/cv/**",
        "tests/test_perception_pipeline.py",
        "scripts/perception_demo.py"
      ],
      "read_only_dependencies": [
        "prosthesis_rl/contracts/**",
        "docs/TECHNICAL_PLAN.md"
      ],
      "produces": [
        "TaskSpec",
        "task-intake provenance"
      ],
      "acceptance": [
        "python3 -m pytest -q tests/test_perception_pipeline.py"
      ]
    },
    {
      "id": "morphology_design",
      "human_owner": "Benji",
      "mission": "Produce valid simulated limb morphology, spatial checks, and simulation geometry assets.",
      "write_paths": [
        "prosthesis_rl/agents/design.py",
        "prosthesis_rl/cad/**"
      ],
      "read_only_dependencies": [
        "prosthesis_rl/contracts/**",
        "prosthesis_rl/sim/**",
        "docs/TECHNICAL_PLAN.md"
      ],
      "consumes": [
        "TaskSpec",
        "SimFeedback",
        "EvalResult"
      ],
      "produces": [
        "MorphologySpec",
        "validation report",
        "simulation geometry asset"
      ]
    },
    {
      "id": "simulation",
      "human_owner": "Nathan",
      "mission": "Run deterministic MuJoCo/HUD scenarios and expose verifier signals for evaluation.",
      "write_paths": [
        "prosthesis_rl/sim/**",
        "assets/clips/**"
      ],
      "read_only_dependencies": [
        "prosthesis_rl/contracts/**",
        "docs/TECHNICAL_PLAN.md"
      ],
      "consumes": [
        "TaskSpec",
        "MorphologySpec",
        "PolicyArtifact",
        "seed"
      ],
      "produces": [
        "SimSpec",
        "EvalResult",
        "reward breakdown",
        "determinism evidence"
      ]
    },
    {
      "id": "policy_optimization",
      "human_owner": "Vasi",
      "mission": "Improve policy/controller behavior using verifier feedback and a bounded rollout budget.",
      "write_paths": [
        "prosthesis_rl/rl/**"
      ],
      "read_only_dependencies": [
        "prosthesis_rl/contracts/**",
        "prosthesis_rl/agents/design.py",
        "prosthesis_rl/sim/**",
        "docs/TECHNICAL_PLAN.md"
      ],
      "consumes": [
        "SimSpec",
        "MorphologySpec",
        "EvalResult"
      ],
      "produces": [
        "PolicyArtifact",
        "ranked rollouts",
        "reward distribution",
        "optional checkpoint"
      ]
    },
    {
      "id": "viewer_api",
      "human_owner": "Vihaan",
      "mission": "Expose sim results through one API boundary and render replayable, contract-backed output.",
      "write_paths": [
        "viewer/**"
      ],
      "read_only_dependencies": [
        "prosthesis_rl/contracts/**",
        "docs/TECHNICAL_PLAN.md"
      ],
      "produces": [
        "viewer build",
        "API compatibility evidence",
        "replay path"
      ],
      "acceptance": [
        "npm --prefix viewer run build"
      ]
    },
    {
      "id": "qa_evidence",
      "human_owner": "shared",
      "mission": "Verify contracts, determinism, end-to-end behavior, build health, and demo evidence.",
      "write_paths": [
        "tests/**",
        "scripts/smoke.py",
        "docs/**"
      ],
      "read_only_dependencies": [
        "prosthesis_rl/**",
        "viewer/**",
        "tasks.py"
      ],
      "produces": [
        "test results",
        "skipped-gate report",
        "evidence manifest"
      ],
      "acceptance": [
        "python3 -m pytest -q",
        "PYTHONPATH=. python3 scripts/smoke.py",
        "PYTHONPATH=. python3 scripts/run_loop.py",
        "npm --prefix viewer run build"
      ]
    }
  ]
}
