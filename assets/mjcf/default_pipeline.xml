<mujoco model="prosthesis_default">
  <compiler angle="radian" meshdir="." />
  <asset>
    <mesh name="upper_arm_mesh" file="upper_arm.stl" />
    <mesh name="forearm_mesh" file="forearm.stl" />
    <mesh name="gripper_mesh" file="gripper.stl" />
  </asset>
  <worldbody>
    <body name="mount" pos="0 0 0">
      <body name="upper_arm" pos="0 0 -0">
        <joint name="shoulder_flex" type="hinge" axis="0 1 0" range="-1.5708 2.0944" />
        <joint name="shoulder_abduct" type="hinge" axis="1 0 0" range="-1.0472 1.5708" />
        <geom type="mesh" mesh="upper_arm_mesh" rgba="0.7 0.72 0.78 1" />
        <body name="forearm" pos="0 0 -0.3">
          <joint name="elbow" type="hinge" axis="0 1 0" range="0 2.2689" />
          <geom type="mesh" mesh="forearm_mesh" rgba="0.7 0.72 0.78 1" />
          <body name="gripper" pos="0 0 -0.26">
            <joint name="wrist" type="hinge" axis="1 0 0" range="-1.0472 1.0472" />
            <geom type="mesh" mesh="gripper_mesh" rgba="0.85 0.6 0.2 1" />
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  <actuator>
    <motor joint="shoulder_flex" gear="20.0" />
    <motor joint="shoulder_abduct" gear="20.0" />
    <motor joint="elbow" gear="20.0" />
    <motor joint="wrist" gear="20.0" />
  </actuator>
</mujoco>