{
  "version": 1,
  "note": "Shared task/dataset spec. Single source of truth for the in-sim dashboard AND (later) the Python HUD env. ids mirror tasks.py ADL_TASKS. weights map 1:1 to prosthesis_rl RewardBreakdown (success/energy_penalty/rom_penalty/collision_penalty). target is MuJoCo world frame; mount is (0,-0.4,1.0), reach ~0.64m.",
  "datasets": [
    {
      "id": "adl",
      "name": "Activities of Daily Living",
      "tasks": [
        {
          "id": "reach_1_1",
          "name": "Reach target",
          "dataset": "adl",
          "arm": "single",
          "target": [0.0, 0.1, 0.63],
          "grader": {
            "weights": {
              "success": 1.0,
              "effort": 0.3,
              "rom": 1.0,
              "stability": 0.2
            },
            "success_threshold_cm": 8
          }
        },
        {
          "id": "grasp_1_1",
          "name": "Grasp object",
          "dataset": "adl",
          "arm": "articulated",
          "target": [0.0, 0.22, 0.95],
          "grader": {
            "weights": {
              "success": 1.0,
              "effort": 0.3,
              "rom": 1.0,
              "stability": 0.3
            },
            "success_threshold_cm": 8
          }
        },
        {
          "id": "feeding_1_1",
          "name": "Feeding motion",
          "dataset": "adl",
          "arm": "articulated",
          "target": [0.18, 0.05, 1.05],
          "grader": {
            "weights": {
              "success": 1.0,
              "effort": 0.4,
              "rom": 1.0,
              "stability": 0.4
            },
            "success_threshold_cm": 8
          }
        }
      ]
    },
    {
      "id": "arm_variants",
      "name": "Arm Variants",
      "tasks": [
        {
          "id": "reach_single_low",
          "name": "Single-DoF low reach",
          "dataset": "arm_variants",
          "arm": "single",
          "target": [0.1, 0.05, 0.55],
          "grader": {
            "weights": {
              "success": 1.0,
              "effort": 0.3,
              "rom": 1.0,
              "stability": 0.2
            },
            "success_threshold_cm": 8
          }
        },
        {
          "id": "reach_artic_high",
          "name": "Articulated high reach",
          "dataset": "arm_variants",
          "arm": "articulated",
          "target": [-0.05, 0.2, 1.05],
          "grader": {
            "weights": {
              "success": 1.0,
              "effort": 0.3,
              "rom": 1.0,
              "stability": 0.3
            },
            "success_threshold_cm": 8
          }
        }
      ]
    },
    {
      "id": "grasping",
      "name": "Grasping (23-DoF hand)",
      "tasks": [
        {
          "id": "grasp_can",
          "name": "Grasp the can",
          "dataset": "grasping",
          "arm": "hand",
          "grasp": true,
          "target": [-0.1, 0.12, 0.55],
          "grader": {
            "weights": {
              "success": 1.0,
              "effort": 0.2,
              "rom": 1.0,
              "stability": 0.3
            },
            "success_threshold_cm": 12
          }
        }
      ]
    }
  ]
}
